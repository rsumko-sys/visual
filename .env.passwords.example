# ALLOWED_PASSWORDS — список паролів для входу (кожен рядок = один пароль)
# Скопіюй в Railway Variables або .env
#
# Формат 1 — по одному на рядок:
# ALLOWED_PASSWORDS=пароль1
# пароль2
# пароль3
#
# Формат 2 — через кому в одному рядку:
# ALLOWED_PASSWORDS=пароль1,пароль2,пароль3
#
# Встав сюди свої паролі з зображення (кожен рядок окремо):
