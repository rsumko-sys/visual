# OSINT Platform 2026 - Environment Template
# Copy to .env and fill in your values

# === Required for Docker ===
DB_USER=osint
DB_PASSWORD=change_me_secure_password
DB_NAME=osint
DB_PORT=5432
REDIS_PASSWORD=change_me_redis_password
REDIS_PORT=6379

# === JWT / Auth (required) ===
JWT_SECRET_KEY=  # min 32 chars, or run: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=     # fallback if JWT_SECRET_KEY not set

# === Local dev (no Docker) ===
# DATABASE_URL=sqlite:///./osint.db
# REDIS_URL=redis://localhost:6379/0

# === API Keys (optional - tools work in mock mode without) ===
SHODAN_API_KEY=
SHODAN_KEY=
OPENAI_API_KEY=
GEOSPY_API_KEY=
PICARTA_API_KEY=
YOUCONTROL_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
HUNTER_API_KEY=

# === Ports ===
API_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
